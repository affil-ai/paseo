{
  "name": "@getpaseo/auth-gateway",
  "version": "0.1.104-beta.4",
  "private": true,
  "description": "Authentication gateway for self-hosted Paseo daemons",
  "bin": {
    "paseo-auth-gateway": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "tsc -p tsconfig.json --incremental false",
    "start": "node dist/index.js",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "better-auth": "1.6.23",
    "better-sqlite3": "12.11.1",
    "http-proxy": "1.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^20.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "ws": "^8.20.0"
  }
}
