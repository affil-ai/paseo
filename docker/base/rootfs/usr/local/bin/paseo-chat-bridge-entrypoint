#!/usr/bin/env bash
set -euo pipefail
trap 'exit 0' INT TERM

: "${PASEO_LISTEN:=0.0.0.0:6767}"
: "${PASEO_CHAT_SLACK_MODE:=socket}"

daemon_port="${PASEO_LISTEN##*:}"
: "${PASEO_CHAT_DAEMON_HOST:=127.0.0.1:${daemon_port}}"

# The inbound HTTP server also hosts the Resend email-intake webhook, which can
# be enabled via chat.email settings regardless of the Slack mode, so the
# container always binds it where the reverse proxy can reach it.
: "${PASEO_CHAT_HTTP_HOST:=0.0.0.0}"

export PASEO_CHAT_DAEMON_HOST
export PASEO_CHAT_HTTP_HOST

entry="$(npm root -g)/@getpaseo/chat/dist/index.js"
if [[ ! -f "$entry" ]]; then
  echo "[paseo] FATAL: chat bridge entrypoint is missing: $entry" >&2
  exit 1
fi

wait_for_daemon() {
  local attempts=0
  until curl -fsS "http://127.0.0.1:${daemon_port}/api/health" >/dev/null 2>&1; do
    attempts=$((attempts + 1))
    if (( attempts == 1 || attempts % 30 == 0 )); then
      echo "[paseo] waiting for daemon health before starting chat bridge" >&2
    fi
    sleep 1
  done
}

while true; do
  wait_for_daemon
  echo "[paseo] starting chat bridge"
  set +e
  node "$entry"
  status=$?
  set -e
  echo "[paseo] chat bridge exited with status ${status}; restarting in 5s" >&2
  sleep 5
done
